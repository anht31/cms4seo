
<!-- About-->
<section class="page-section link-decorator" id="about">
    <div class="container">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">
                <span @CMS.Attribute("Section.Timeline.Header")>
                    @Setting.Contents["Section.Timeline.Header"]
                </span>
            </h2>
            <h3 class="section-subheading text-muted">
                <span @CMS.Attribute("Section.Timeline.Description1")>
                    @Setting.Contents["Section.Timeline.Description1"]
                </span>

                <a @CMS.Attribute("Section.Timeline.Description2.Href" , "Section.Timeline.Description2.Text")
                   href="@Setting.Contents["Section.Timeline.Description2.Href"]" data-toggle="tooltip" title="Tell me more!">
                    @Setting.Contents["Section.Timeline.Description2.Text"]
                </a>
                <span @CMS.Attribute("Section.Timeline.Description2")>
                    @Setting.Contents["Section.Timeline.Description2"]
                </span>

                <a @CMS.Attribute("Section.Timeline.Description3.Href", "Section.Timeline.Description3.Text")
                   href="@Setting.Contents["Section.Timeline.Description3.Href"]" data-toggle="tooltip" title="Tell me more!">
                    @Setting.Contents["Section.Timeline.Description3.Text"]
                </a>
                <span @CMS.Attribute("Section.Timeline.Description3")>
                    @Setting.Contents["Section.Timeline.Description3"]
                </span>

                <a @CMS.Attribute("Section.Timeline.Description4.Href", "Section.Timeline.Description4.Text")
                   href="@Setting.Contents["Section.Timeline.Description4.Href"]" data-toggle="tooltip" title="Tell me more!">
                    @Setting.Contents["Section.Timeline.Description4.Text"]
