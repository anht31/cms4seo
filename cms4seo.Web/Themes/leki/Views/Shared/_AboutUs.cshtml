                <span @CMS.Attribute("Section.Timeline.Description5")>
                    @Setting.Contents["Section.Timeline.Description5"]
                </span>

                <a @CMS.Attribute("Section.Timeline.Description6.Href", "Section.Timeline.Description6.Text")
                   href="@Setting.Contents["Section.Timeline.Description6.Href"]" data-toggle="tooltip" title="Tell me more!">
                    @Setting.Contents["Section.Timeline.Description6.Text"]
                </a>
                <span @CMS.Attribute("Section.Timeline.Description6")>
                    @Setting.Contents["Section.Timeline.Description6"]
                </span>

            </h3>
        </div>
        <ul class="timeline">
            <li>
                <div class="timeline-image">
                    <img @CMS.Attribute("Section.Timeline.Year1.Image") 
                        src="@Setting.Contents["Section.Timeline.Year1.Image"]" class="rounded-circle img-fluid" alt="size-200x200"/>
                </div>
                <div class="timeline-panel">
                    <div class="timeline-heading">
                        <h4>
                            <span @CMS.Attribute("Section.Timeline.Year1.Name")>
                                @Setting.Contents["Section.Timeline.Year1.Name"]
                            </span>
                        </h4>
                        <h4 class="subheading">
                            <span @CMS.Attribute("Section.Timeline.Year1.Header")>
                                @Setting.Contents["Section.Timeline.Year1.Header"]
                            </span>
                        </h4>
                    </div>
                    <div class="timeline-body">
                        <p class="text-muted">
                            <span @CMS.Attribute("Section.Timeline.Year1.Brief")>
                                @Setting.Contents["Section.Timeline.Year1.Brief"]
                            </span>
                        </p>
                    </div>
                </div>
            </li>
