@model Product



<div class="col-lg-4 col-sm-6 mb-4">
    <div class="portfolio-item">
        <a class="portfolio-link" data-toggle="modal" href="#portfolioModal-@Model.Id">
            <div class="portfolio-hover">
                <div class="portfolio-hover-content"><i class="fas fa-plus fa-3x"></i></div>
            </div>
            <img class="img-fluid" src="@Model.Avatar" alt="@Model.Slug"/>
        </a>
        <div class="portfolio-caption">
            <div class="portfolio-caption-heading">@Model.Name</div>
            <div class="portfolio-caption-subheading text-muted">@Model.Brief.ShortenText50()</div>
        </div>
    </div>
</div>

<!-- portfolioModal-@Model.Id-->
<div class="portfolio-modal modal fade" id="portfolioModal-@Model.Id" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="close-modal" data-dismiss="modal"><img src="/Themes/leki/Assets/img/close-icon.svg" /></div>
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="modal-body">
                            <!-- Project Details Go Here-->
                            <h2 class="text-uppercase">@Model.Name</h2>
                            <p class="item-intro text-muted">@Model.Brief</p>
                            <img class="img-fluid d-block mx-auto" src="@(Model.Photos.FirstOrDefault() != null ? Model.Photos.FirstOrDefault().LgPath : "")" alt="" />
                            <p>
                                @if (Model.Summary != null)
                                {
                                    @Html.Raw(Model.Summary)
                                }
                            </p>
                            <ul class="list-inline">
                                <li>Date: @Model.Created</li>
                                <li>Version Support: 1.0.0.7</li>
                                <li>Category: @Model.Category.Name</li>
                            </ul>
                            <button class="btn btn-primary" data-dismiss="modal" type="button"><i class="fas fa-times mr-1"></i>
                                <span @CMS.Attribute("Section.Portfolio.Model.Close")>
                                    @Setting.Contents["Section.Portfolio.Model.Close"]
                                </span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>