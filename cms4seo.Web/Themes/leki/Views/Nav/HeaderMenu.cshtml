
@model IEnumerable<Category>



<!-- Navigation-->
<nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
    <div class="container">
        <a class="navbar-brand js-scroll-trigger" href="/" target="_top">
            <img src="~/Themes/leki/Assets/logo/cms4seo-outer-15.png" />
        </a>

        <button class="navbar-toggler navbar-toggler-right" type="button" data-toggle="collapse" 
                data-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" 
                aria-label="Toggle navigation">Menu<i class="fa fa-bars ml-1"></i>
        </button>

        <div class="collapse navbar-collapse" id="navbarResponsive">
            <ul class="navbar-nav text-uppercase ml-auto">
            @foreach (var item in Model.Where(x => x.IsMenu))
            {
                <li class="nav-item">
                    <a class="nav-link" href="@(item.Href != "#" ? item.Href : item.Slug)">@item.Name</a>
                </li>
            }


            </ul>
        </div>
    </div>
</nav>
